FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 800;

boundaryField
{
    base
    {
        type            omegaWallFunction;
        value           uniform 800;
    }
    top
    {
        type            zeroGradient;
    }

    "(front|back)"
    {
        type            cyclic;
    }

	"(left|right)"
    {
        type            cyclic;
    }
}



